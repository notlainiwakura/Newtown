{
  "name": "newtown",
  "version": "0.1.0",
  "description": "A local-first multi-resident town template powered by OpenAI-compatible inference",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "newtown": "./bin/newtown.js"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e.test.ts --timeout 60000",
    "test:e2e:deploy": "DEPLOY_TEST=1 vitest run test/e2e.test.ts --timeout 60000",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "format": "oxlint --fix src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "@types/nodemailer": "^7.0.9",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^17.2.3",
    "grammy": "^1.31.3",
    "inquirer": "^12.3.2",
    "json5": "^2.2.3",
    "nanoid": "^5.0.9",
    "nodemailer": "^8.0.1",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright-core": "^1.49.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/pdf-parse": "^1.1.5",
    "oxlint": "^0.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "ai",
    "town",
    "simulation",
    "self-hosted",
    "multi-agent"
  ],
  "author": "",
  "license": "MIT"
}
