# Newtown Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI-compatible model endpoint
OPENAI_BASE_URL=http://192.168.68.69:8080/v1
OPENAI_MODEL=MiniMax-M2.7
OPENAI_API_KEY=not-needed

# Character runtime uses the same endpoint by default
CHARACTER_BASE_URL=http://192.168.68.69:8080/v1
CHARACTER_MODEL=MiniMax-M2.7
CHARACTER_PROVIDER=openai

# Shared local home for isolated Newtown residents
NEWTOWN_HOME=C:/Users/akaik/.newtown

# Inter-resident auth for local object/peer APIs
LAIN_INTERLINK_TOKEN=newtown-interlink

# Local owner/admin gate for the browser UI
LAIN_OWNER_TOKEN=newtown

# Disable research tools for all residents
ENABLE_RESEARCH=0

# Optional: mirror a copy of local memories into Max's ChromaDB over Twingate/LAN
CHROMA_MIRROR_ENABLED=1
CHROMA_BASE_URL=http://192.168.68.69:8001
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_COLLECTION_PREFIX=newtown-memory
CHROMA_TIMEOUT_MS=4000

# Optional: Web server port (default: 3000)
# PORT=3000

# Optional: lock down the local web UI with a bearer key
# LAIN_WEB_API_KEY=change-me

# Optional: dashboard possession token (defaults to "newtown")
# POSSESSION_TOKEN=newtown

# Optional: Telegram integration if you want the town guide on Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
